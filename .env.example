# Backend
DATABASE_URL=postgresql+psycopg://karkov:karkov@db:5432/karkov
SECRET_KEY=change-me-to-a-random-32-plus-character-string!!
ADMIN_EMAIL=admin@karkov.example.com
ADMIN_PASSWORD=change-me
ADMIN_NAME=Administrator
# Local dev: http://localhost:3000 — Prod (docker-compose.prod.yml): https://karkovweekend.dk
PUBLIC_BASE_URL=http://localhost:3000
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
CORS_ORIGINS=["http://localhost:3000"]

# Email delivery (optional). When SMTP_HOST is set, real emails go out via SMTP;
# otherwise we just write to the email_outbox table and stdout.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_USE_TLS=true
# SMTP_STARTTLS=true
# SMTP_FROM_ADDRESS=no-reply@karkov.example.com
# SMTP_FROM_NAME=Karkov Weekend

# Web Push / VAPID (optional). Leave blank in dev to auto-generate an ephemeral
# keypair on startup; set both in production so subscriptions survive restarts.
# Generate with: `openssl ecparam -genkey -name prime256v1 -noout -out vapid.pem`
# and read out the matching base64url public key.
# VAPID_PRIVATE_KEY=
# VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:no-reply@karkov.example.com

# Postgres
POSTGRES_DB=karkov
POSTGRES_USER=karkov
POSTGRES_PASSWORD=karkov

# Frontend (used at build time for local `npm run dev`; docker-compose.prod.yml pins `/api/v1` instead)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
# Optional Google Maps Embed API key. Leave blank to use the keyless iframe.
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
